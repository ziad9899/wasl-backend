NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/wasl?retryWrites=true&w=majority

JWT_ACCESS_SECRET=replace_with_random_string_min_64_chars
JWT_REFRESH_SECRET=replace_with_random_string_min_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

JWT_ADMIN_ACCESS_SECRET=replace_with_random_string_min_64_chars
JWT_ADMIN_REFRESH_SECRET=replace_with_random_string_min_64_chars
JWT_ADMIN_ACCESS_EXPIRES=1h
JWT_ADMIN_REFRESH_EXPIRES=7d

OTP_PEPPER=replace_with_random_pepper_string

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

AUTHENTICA_API_KEY=
AUTHENTICA_SENDER=WASL

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

REDIS_URL=redis://localhost:6379

CLIENT_URL=https://wasl.sa

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=
MOYASAR_STUB=true

TABBY_SECRET_KEY=
TABBY_MERCHANT_CODE=
TABBY_WEBHOOK_SECRET=
TABBY_STUB=true

UNIFONIC_API_KEY=
UNIFONIC_BASE_URL=https://api.unifonic.com
UNIFONIC_STUB=true

STUB_CHECKOUT_BASE=https://stub.wasl.sa

SEED_ADMIN_EMAIL=admin@wasl.sa
SEED_ADMIN_PASSWORD=Wasl@2026!
